{
  "name": "recode",
  "version": "0.1.0",
  "description": "Recode is a coding agent built with TypeScript + Bun, featuring a Senren-inspired TUI.",
  "private": true,
  "type": "module",
  "bin": {
    "recode": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "build": "bun run scripts/build.ts --single",
    "build:all": "bun run scripts/build.ts",
    "test": "bun test ./src/agent ./src/cli ./src/config ./src/history ./src/models ./src/runtime ./src/tools ./src/tui"
  },
  "dependencies": {
    "@opentui/core": "^0.1.99",
    "@opentui/solid": "^0.1.99",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
