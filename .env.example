# Optional path override for the global config file.
# Default: ~/.recode/config.json
BANKA_CONFIG_PATH=~/.recode/config.json

# Optional active provider ID from ~/.recode/config.json.
# This lets you switch the active configured provider without editing the file.
BANKA_ACTIVE_PROVIDER=

# Optional provider kind override: openai | openai-chat | anthropic
# openai: OpenAI Responses API
# openai-chat: OpenAI Chat Completions API
# anthropic: Anthropic Messages API
BANKA_PROVIDER=

# Optional API key override. Leave empty when the configured provider already stores it
# or when your local OpenAI-compatible endpoint does not require auth.
BANKA_API_KEY=

# Optional base URL override.
# OpenAI:    https://api.openai.com/v1
# Anthropic: https://api.anthropic.com/v1
# Ollama:    http://127.0.0.1:11434/v1
# OpenRouter: https://openrouter.ai/api/v1
BANKA_BASE_URL=

# Optional model ID override.
BANKA_MODEL=
